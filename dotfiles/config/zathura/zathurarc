set adjust-open width
set database sqlite
set font "monospace 16"
set page-h-padding 10
set page-v-padding 10
set recolor "true"
set selection-clipboard clipboard
set selection-notification 0
set statusbar-basename 1
set statusbar-h-padding 10
set statusbar-v-padding 10
map u scroll half-up
map d scroll half-down
map D toggle_page_mode
map r reload
map R rotate
map K zoom in
map J zoom out
map i recolor
map p print
map gg goto top
map Q quit

set default-bg              "#1e1e2e"
set default-fg              "#cdd6f4"
set recolor-lightcolor      "#1e1e2e"
set recolor-darkcolor       "#cdd6f4"

set statusbar-bg            "#11111b"
set statusbar-fg            "#b4befe"
set inputbar-bg             "#11111b"
set inputbar-fg             "#b4befe"

set notification-bg         "#11111b"
set notification-fg         "#b4befe"
set notification-error-bg   "#11111b"
set notification-error-fg   "#f38ba8"
set notification-warning-bg "#b4befe"
set notification-warning-fg "#c8043a"

set index-bg                "#1e1e2e"
set index-fg                "#cdd6f4"
set index-active-bg         "#b4befe"
set index-active-fg         "#11111b"
set highlight-color         "rgba(180, 190, 254, 0.5)"
set highlight-active-color  "rgba(129, 146, 253, 0.5)"
set highlight-fg            "#11111b"

set completion-bg           "#11111b"
set completion-fg           "#b4befe"
set completion-group-bg     "#11111b"
set completion-group-fg     "#b4befe"
set completion-highlight-fg "#11111b"
set completion-highlight-bg "#b4befe"
